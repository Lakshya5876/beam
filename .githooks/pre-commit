#!/usr/bin/env bash
# pre-commit — fingerprint -> scoped gate -> ledger receipt. Mechanical:
# this runs because git runs it, not because the model chose to.
set -u
cd "$(git rev-parse --show-toplevel)"

# ---------------------------------------------------------- KILL SWITCH (K1)
# Layered, deny-first. settings.json denying "Bash(SKIP_GATE=*)" is the hard
# layer; this hook adds the agent-marker refusal (in case an env-prefixed
# command slips a matcher) and a human-presence TTY backstop — NOT a
# categorical guarantee. Documented human path: run the bypass in a PLAIN
# shell, never through the agent.
if [ -n "${SKIP_GATE:-}" ]; then
  if [ -n "${CLAUDECODE:-}" ] || [ -n "${CLAUDE_CODE:-}" ] || [ -n "${CLAUDE_CODE_ENTRYPOINT:-}" ]; then
    echo "SKIP_GATE refused: agent-environment marker present. Bypass is a human-only action in a plain shell." >&2
    exit 1
  fi
  if [ ! -r /dev/tty ]; then
    echo "SKIP_GATE refused: no controlling TTY — human presence required." >&2
    exit 1
  fi
  printf "SKIP_GATE bypass requested. Type a non-empty REASON to confirm (empty aborts): " > /dev/tty
  if ! read -r reason < /dev/tty; then
    echo "SKIP_GATE refused: could not read confirmation from /dev/tty." >&2
    exit 1
  fi
  if [ -z "$reason" ]; then
    echo "SKIP_GATE aborted: empty reason." >&2
    exit 1
  fi
  # The commit sha does not exist yet at pre-commit time; the post-commit
  # hook attaches the append-only audit note (git notes --ref=bypasses).
  mkdir -p .claude
  printf '%s\n' "$reason" > .claude/.pending_bypass
  echo "BYPASS ACCEPTED: '$reason' — git note will be attached post-commit; the 24h re-verify clock runs on the COMMITTER DATE (pre-push enforces it)."
  exit 0
fi

# ----------------------------------------------------------- CRASH GUARD
# Run gate.sh; capture the exit code; ANY non-zero exit is a block —
# deliberate gate block, missing dependency, or scripting crash alike.
# Never a specific-code check that would silently pass on an unexpected
# crash code. stderr is emitted verbatim.
out="$(.githooks/gate.sh commit 2>&1)"
code=$?
printf '%s\n' "$out"
if [ "$code" -ne 0 ]; then
  echo "" >&2
  echo "PRE-COMMIT: COMMIT BLOCKED — gate.sh exited $code (block or crash; both refuse the commit)." >&2
  exit 1
fi
exit 0
