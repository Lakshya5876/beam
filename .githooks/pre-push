#!/usr/bin/env bash
# pre-push — receipt validation + force guard + bypass-deadline enforcement.
# Receives: $1 = remote name, $2 = remote URL; stdin lines:
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
set -u
cd "$(git rev-parse --show-toplevel)"
STATE_FILE=".claude/gate_state.json"
remote="${1:-origin}"
ZERO=0000000000000000000000000000000000000000

state_get() {
  [ -f "$STATE_FILE" ] || { echo ""; return 0; }
  node -e '
    const j = JSON.parse(require("fs").readFileSync(process.argv[1], "utf8"));
    let v = j;
    for (const k of process.argv[2].split(".")) { if (v == null) break; v = v[k]; }
    if (v == null) process.exit(0);
    process.stdout.write(typeof v === "object" ? JSON.stringify(v) : String(v));
  ' "$STATE_FILE" "$1"
}

# (1) Bypass-trail deletion guard on the argument vector (prescribed check —
# must return exit code 1):
if echo "$@" | grep -qE ":refs/notes/bypasses"; then
  echo "PUSH REFUSED: refspec targets the bypass audit trail (refs/notes/bypasses is append-only)." >&2
  exit 1
fi

# (2) Fetch the shared bypass trail so deadline math sees notes from other
# clones. Tolerate a missing/offline remote — absence of NEW notes cannot
# unblock anything below.
git fetch "$remote" '+refs/notes/bypasses:refs/notes/bypasses' >/dev/null 2>&1 || true

push_blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_ref:-}" ] && continue

  # (3) Force syntax: a '+'-prefixed refspec cannot be pattern-matched by the
  # settings deny list (CLAUDE.md P3) — refuse it here. Honest scope note:
  # git strips the '+' before invoking this hook in most versions, so this
  # check is belt-and-braces over the protected-branch refusal below, which
  # is what actually stops a forced rewrite of protected history.
  case "$local_ref" in
    +*) echo "PUSH REFUSED: force refspec '+...' is banned (constitution P3)." >&2; exit 1 ;;
  esac

  # (4) Protected branches — never pushed directly, forced or not.
  case "$remote_ref" in
    refs/heads/main|refs/heads/master|refs/heads/develop)
      echo "PUSH REFUSED: direct push to protected branch '${remote_ref#refs/heads/}'. Open a PR from a feature branch." >&2
      exit 1 ;;
    refs/notes/bypasses)
      if [ "$local_sha" = "$ZERO" ]; then
        echo "PUSH REFUSED: deletion of the bypass audit trail." >&2
        exit 1
      fi ;;
  esac

  # Branch deletions of ordinary refs carry no commits to verify.
  [ "$local_sha" = "$ZERO" ] && continue

  # (5) RECEIPT VALIDATION — keyed by the COMMIT TREE, never the working-tree
  # fingerprint (which can never equal a post-commit state).
  head_tree="$(git rev-parse "${local_sha}^{tree}" 2>/dev/null)" || {
    echo "PUSH REFUSED: cannot resolve tree for $local_sha." >&2; exit 1; }
  receipt="$(state_get "receipts.trees.${head_tree}.result")"
  if [ "$receipt" != "pass" ]; then
    # A bypassed commit has no receipt — allowed only within its 24h window.
    if git notes --ref=bypasses show "$local_sha" >/dev/null 2>&1; then
      committer_ts="$(git show -s --format=%ct "$local_sha")"
      age=$(( $(date +%s) - committer_ts ))
      if [ "$age" -gt 86400 ]; then
        echo "PUSH REFUSED: bypassed commit ${local_sha:0:8} is older than 24h (COMMITTER DATE) with no clean gate re-run receipt. Re-run the gate (.githooks/gate.sh full) first." >&2
        exit 1
      fi
      echo "WARNING: pushing bypassed commit ${local_sha:0:8} within its 24h window — /review must re-run the skipped gates." >&2
    else
      echo "PUSH REFUSED: no passing gate receipt for commit tree ${head_tree} of ${local_sha:0:8}. Run the gate before pushing." >&2
      exit 1
    fi
  fi

  # (6) 24h DEADLINE SWEEP over every bypass-noted ancestor being pushed —
  # COMMITTER DATES, never ledger timestamps.
  while read -r _note_obj noted_commit; do
    [ -z "${noted_commit:-}" ] && continue
    git merge-base --is-ancestor "$noted_commit" "$local_sha" 2>/dev/null || continue
    committer_ts="$(git show -s --format=%ct "$noted_commit")"
    age=$(( $(date +%s) - committer_ts ))
    if [ "$age" -gt 86400 ]; then
      noted_tree="$(git rev-parse "${noted_commit}^{tree}")"
      rerun="$(state_get "receipts.trees.${noted_tree}.result")"
      if [ "$rerun" != "pass" ]; then
        echo "PUSH REFUSED: bypass on ${noted_commit:0:8} expired (>24h by committer date) without a clean gate re-run receipt." >&2
        exit 1
      fi
    fi
  done < <(git notes --ref=bypasses list 2>/dev/null || true)
done

exit 0
